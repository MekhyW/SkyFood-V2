<?xml version="1.0" encoding="UTF-8"?>
<root BTCPP_format="4"
      main_tree_to_execute="DeliveryMission">
  <BehaviorTree ID="DeliveryMission">
    <Sequence name="delivery_sequence">
      <SaveMap name="Save Map"
               map_name="delivery_map"
               save_path="/tmp/maps"/>
      <PlaySound name="Departure Chime"
                 file_path="/opt/sounds/departure.wav"
                 blocking="false"/>
      <ControlCompartment name="Open UL Door"
                          door_id="UL"
                          open="true"/>
      <NavigateToPOI name="Go to Kitchen"
                     poi_name="kitchen_pickup"/>
      <PlaySound name="Arrival Chime"
                 file_path="/opt/sounds/arrival.wav"
                 blocking="true"/>
    </Sequence>
  </BehaviorTree>

  <!-- Description of Node Models (used by Groot) -->
  <TreeNodesModel>
    <Action ID="ControlCompartment">
      <input_port name="door_id">&#10;        Door to control: UL | UR | DL | DR | ALL&#10;      </input_port>
      <input_port name="open">&#10;        true = open the door, false = close it&#10;      </input_port>
    </Action>
    <Action ID="NavigateToPOI">
      <input_port name="poi_name">&#10;        Name of the target POI (must be registered via /poi_manager/save_poi)&#10;      </input_port>
    </Action>
    <Action ID="PlaySound">
      <input_port name="file_path">&#10;        Absolute path to a WAV / MP3 / OGG file&#10;      </input_port>
      <input_port name="blocking"
                  default="false">&#10;        true = block until playback finishes; false = fire-and-forget&#10;      </input_port>
    </Action>
    <Action ID="SaveMap">
      <input_port name="map_name">&#10;        Filename stem for the saved map (e.g. "warehouse_v2")&#10;      </input_port>
      <input_port name="save_path">&#10;        Absolute directory path to write map files into&#10;      </input_port>
    </Action>
  </TreeNodesModel>

</root>
