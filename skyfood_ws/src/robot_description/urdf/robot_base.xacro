<?xml version='1.0'?>

<robot name="robot" xmlns:xacro="http://www.ros.org/wiki/xacro">

  <xacro:include filename="$(find robot_description)/urdf/robot_base.gazebo" />
  <xacro:include filename="$(find robot_description)/urdf/materials.xacro" />
  <xacro:include filename="$(find robot_description)/urdf/xacro_variables.xacro" />
  <xacro:include filename="$(find robot_description)/urdf/wheels.xacro" />
  <xacro:include filename="$(find robot_description)/urdf/caster_ball.xacro" />
  <xacro:include filename="$(find robot_description)/urdf/sensors.xacro" />

  <!-- Add dummy base link -->
  <link name="base_link">
  </link>

  <link name='chassis'>
    <pose>0 0 0.1 0 0 0</pose>

    <inertial>
      <!-- Combined CoM: base at z=0, tower (0.64m tall) centered at z=0.58m
           Approximate CoM ≈ z=0.35m relative to chassis link origin -->
      <origin xyz="0.0 0 0.35" rpy="0 0 0"/>
      <mass value="30.0"/>
      <!-- Ixx = (1/12)*m*(w^2+h^2) using tower dims as dominant: w=0.448, H=0.64 -->
      <!-- Approximate as tall box: Ixx ~= (1/12)*30*(0.448^2 + 0.64^2) = 1.523 -->
      <!-- Iyy ~= (1/12)*30*(0.478^2 + 0.64^2) = 1.597                          -->
      <!-- Izz ~= (1/12)*30*(0.478^2 + 0.448^2) = 0.803                          -->
      <inertia
          ixx="1.52" ixy="0" ixz="0"
          iyy="1.60" iyz="0"
          izz="0.80"
      />
    </inertial>

    <collision name='collision'>
      <geometry>
        <box size="${chasis_box_length} ${chasis_box_width} ${chasis_box_height}"/>
      </geometry>
    </collision>

    <visual name='chassis_visual'>
      <origin xyz="0 0 0" rpy=" 0 0 0"/>
      <geometry>
        <box size="${chasis_box_length} ${chasis_box_width} ${chasis_box_height}"/>
      </geometry>
      <material name="red"/>
    </visual>

    <collision name='tower_collision'>
      <origin xyz="0 0 0.58" rpy="0 0 0"/>
      <geometry>
        <box size="${tower_box_length} ${tower_box_width} ${tower_box_height}"/>
      </geometry>
    </collision>


    <visual name='tower_visual'>
      <origin xyz="0 0 0.58" rpy="0 0 0"/>
      <geometry>
        <box size="${tower_box_length} ${tower_box_width} ${tower_box_height}"/>
      </geometry>
      <material name="red"/>
    </visual>

  </link>

  <joint name="base_joint" type="fixed">
    <parent link="base_link"/>
    <child link="chassis"/>
    <origin xyz="0 0 0" rpy="0 0 0"/>
  </joint>

  <link name="imu_link">
  </link>

  <joint name="imu_joint" type="fixed">
    <parent link="chassis"/>
    <child link="imu_link"/>
    <origin xyz="0 0 0" rpy="0 0 0"/>
  </joint>


  <link name="lidar_link">
    <visual name="lidar_visual">
      <origin xyz="0 0 0.01" rpy="0 0 0"/>
      <geometry>
        <cylinder radius="0.05" length="0.035"/>
      </geometry>
    </visual>
  </link>

  <joint name="lidar_joint" type="fixed">
    <parent link="chassis"/>
    <child link="lidar_link"/>
    <origin xyz="0 0 0.18" rpy="0 0 0"/>
  </joint>


  <link name="camera_link">
    <visual name="camera_visual">
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <box size="0.02 0.15 0.1"/>
      </geometry>
    </visual>
  </link>

  <joint name="camera_joint" type="fixed">
    <parent link="chassis"/>
    <child link="camera_link"/>
    <origin xyz="0.239 0 0.84" rpy="0 0 0"/>
  </joint>


  <!-- Include wheel and caster macros -->
  <xacro:wheels_macro />
  <xacro:caster_balls_macro />

</robot>